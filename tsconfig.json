{
  "compilerOptions": {
    "module": "es2022",
    "target": "es2022",
    "lib": ["es2022", "DOM"],
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node", "vitest"],
    "baseUrl": ".",
    "paths": {
      "kanun": ["src/index.ts"],
      "karun": ["src/index.ts"]
    }
  },
  "exclude": [
    "**/console/bin",
    "dist",
    "**/dist",
    "**/**/dist",
    "**/node_modules",
    "node_modules",
    "**/node_modules/*",
    "**/public/**",
    "**/storage/**",
    "eslint.config.js",
    "jest.config.ts",
    "arquebus.config.js",
    "**/coverage/**"
  ],
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}
